generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Inquiry {
  id        String    @id @default(cuid())
  userId    String
  userEmail String
  userName  String
  category  String
  title     String
  content   String
  status    String    @default("pending")
  reply     String?
  repliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}
